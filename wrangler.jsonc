{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "findthewhy",
  "main": "worker/index.mjs",
  "compatibility_date": "2024-12-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "www",
    "binding": "ASSETS",
    "not_found_handling": "none"
  },
  "build": {
    "command": "node scripts/sync-www.mjs"
  }
}
